# FortiGate
FORTIGATE_HOST=186.30.30.226
FORTIGATE_TOKEN=cambiar_en_railway
FORTIGATE_VERIFY_SSL=false
FORTIGATE_TIMEOUT_SECONDS=15

# Database — AWS RDS MySQL 8
# Formato: mysql+pymysql://usuario:contraseña@endpoint-rds:3306/nombre_bd?charset=utf8mb4
# Si la contraseña tiene caracteres especiales, codifícala con urllib.parse.quote
DATABASE_URL=mysql+pymysql://admin:password@mi-instancia.xxxxx.us-east-1.rds.amazonaws.com:3306/fortigate_monitor?charset=utf8mb4

# SSL para RDS (opcional pero recomendado en producción)
# Descarga el bundle CA de AWS: https://docs.aws.amazon.com/AmazonRDS/latest/UserGuide/UsingWithRDS.SSL.html
# DATABASE_SSL_CA=/path/to/global-bundle.pem

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=1

# Security
INTERNAL_CRON_TOKEN=cambiar_en_railway
# Producción: https://vpn-monitor-lte.vercel.app
# Backend producción: https://vpnmonitorlte-production.up.railway.app
CORS_ORIGINS=http://localhost:5173,https://vpn-monitor-lte.vercel.app

# Logging
LOG_LEVEL=INFO
LOG_JSON=true

# Timezone
TZ=America/Bogota

# Retention
SNAPSHOT_RETENTION_DAYS=60

# LTE / Fibra channel inference
LTE_TRAFFIC_THRESHOLD_BYTES_PER_MIN=10240
LTE_EVALUATION_WINDOW_MINUTES=15
